# pyATS test-runner image for the in-cluster ArgoCD PostSync hook.
# Build + push to the lab registry so the lab cluster can pull it:
#   docker build -f pyats/Dockerfile-pyats -t 192.168.155.250:5000/pyats-clab:latest .
#   docker push 192.168.155.250:5000/pyats-clab:latest
#
# The pyATS base image is amd64-only; pin the platform so it builds the same way
# on Apple Silicon (emulated) and matches an amd64 lab cluster.
FROM --platform=linux/amd64 ciscotestautomation/pyats:latest

WORKDIR /pyats

# pyATS is already in the base image - only pyeapi is missing.
RUN pip3 install --no-cache-dir pyeapi==1.0.4

# Bake the test harness in; the router config under test is per-PR (mounted by
# clabernetes from this repo's topology/base), the harness itself is stable.
COPY pyats/run_test.py ./run_test.py
COPY pyats/inventory/testbed.yaml ./inventory/testbed.yaml

ENTRYPOINT ["python3", "/pyats/run_test.py"]
